# FinSight Backend Environment Variables
# Copy this file to .env and fill in your API keys

# --- Member 2: Logic & Algos ---

# Categorization Strategy (Strategy Pattern)
# Values: 'rule' (default) or 'ml'
CATEGORIZATION_STRATEGY=rule

# Mailjet (Observer Pattern - Email Alerts)
# Sign up at https://www.mailjet.com/ (200 free emails/day, no credit card)
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
MAILJET_SENDER_EMAIL=noreply@finsight.app
MAILJET_RECIPIENT_EMAIL=user@example.com

# Firebase Cloud Messaging (Observer Pattern - Push Notifications)
# Get from Firebase Console > Project Settings > Cloud Messaging
FIREBASE_SERVER_KEY=
FIREBASE_DEVICE_TOKEN=

# ExchangeRate-API (Chain of Responsibility - Primary)
# Sign up at https://www.exchangerate-api.com/ (1500 free req/month)
EXCHANGERATE_API_KEY=

# Open Exchange Rates (Chain of Responsibility - Secondary)
# Sign up at https://openexchangerates.org/ (1000 free req/month)
OPENEXCHANGE_APP_ID=

# --- Member 1: Infrastructure ---
DATABASE_URL=postgresql://user:password@db:5432/finsight_db
SECRET_KEY=supersecretkey
