# FinSight Backend Environment Variables
# SQLite fallback for local development (no PostgreSQL needed)
DATABASE_URL=postgresql://user:password@db:5432/finsight_db
SECRET_KEY=supersecretkey

# Categorization Strategy: 'rule' (default) or 'ml'
CATEGORIZATION_STRATEGY=rule

# Mailjet (Observer Pattern - Email Alerts) — leave empty for dev mode console fallback
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
MAILJET_SENDER_EMAIL=noreply@finsight.app
MAILJET_RECIPIENT_EMAIL=user@example.com

# Firebase Cloud Messaging (Observer Pattern - Push) — leave empty for dev mode
FIREBASE_SERVER_KEY=
FIREBASE_DEVICE_TOKEN=

# ExchangeRate-API (Chain of Responsibility - Primary)
EXCHANGERATE_API_KEY=

# Open Exchange Rates (Chain of Responsibility - Secondary)
OPENEXCHANGE_APP_ID=

# Alpha Vantage (Investment data)
ALPHA_VANTAGE_API_KEY=demo
